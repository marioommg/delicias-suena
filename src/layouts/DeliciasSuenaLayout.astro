---
import "../styles/delicias-suena.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Delicias Suena — Un diario de sonidos del barrio.",
  description = "Un paseo sonoro por el barrio de Delicias. Mapa interactivo, fonoteca y testimonios de vecinos.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <title>{title}</title>
    <slot name="head" />
  </head>
  <body class="bg-white text-zinc-900 font-sans antialiased">
    <slot />
  </body>
</html>
