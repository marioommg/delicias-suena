          if (nameField) nameField.style.display = "block";
          if (label) label.textContent = "Ubicación seleccionada";
        }
      }

      async function reverseGeocode(lat, lng) {
        if (pickerCoordsEl) {
          pickerCoordsEl.textContent = "⏳ Buscando dirección...";
          pickerCoordsEl.className = "picker-coords";
        }
        try {
          const url = `https://nominatim.openstreetmap.org/reverse?lat=${lat}&lon=${lng}&format=json&accept-language=es`;
          const res = await fetch(url);
          if (!res.ok) throw new Error("Error fetching address");
          const data = await res.json();
          if (data && data.address) {
            const road = data.address.road || "";
            const houseNumber = data.address.house_number || "";
            let addressText = "";
            if (road) {
              addressText = road + (houseNumber ? `, ${houseNumber}` : "");
            } else if (data.address.pedestrian) {
              addressText = data.address.pedestrian + (houseNumber ? `, ${houseNumber}` : "");
            } else if (data.address.suburb) {
              addressText = data.address.suburb;
            } else {
              addressText = data.display_name.split(",").slice(0, 2).join(",");
            }
            if (pickerCoordsEl) {
              pickerCoordsEl.textContent = `📍 ${addressText}`;
              pickerCoordsEl.className = "picker-coords has-coords";
            }
          } else {
            throw new Error("No address data");
          }
        } catch (err) {
          console.error("Reverse geocoding error:", err);
          if (pickerCoordsEl) {
            pickerCoordsEl.textContent = `📍 ${lat.toFixed(5)}, ${lng.toFixed(5)}`;
            pickerCoordsEl.className = "picker-coords has-coords";
          }
        }
      }

      // ─── Funciones del Mapa Selección ──────────────────────────────────────
      function enterMapSelectionMode() {
        if (mapSelectionMode) return;
        mapSelectionMode = true;
        isChangingLocation = false;
        previousPanelState = panelState;

        // Colapsar el panel inferior
        setPanelState(0);

        // Cambiar cursor del mapa
        const mapEl = document.getElementById("fonoteca-map");
        if (mapEl) mapEl.classList.add("selecting-location");

        // Mostrar el banner superior
        const banner = document.getElementById("map-selection-banner");
        if (banner) {
          banner.style.display = "block";
          requestAnimationFrame(() => banner.classList.add("active"));
        }

        // Ocultar botones flotantes
        const fab = document.getElementById("btn-upload-audio");
        if (fab) fab.style.opacity = "0";
        const paseoBtn = document.getElementById("btn-paseo-floating");
        if (paseoBtn) paseoBtn.style.opacity = "0";
      }

      function exitMapSelectionMode(restorePanel = true) {
        if (!mapSelectionMode) return;
        mapSelectionMode = false;

        // Restaurar cursor
        const mapEl = document.getElementById("fonoteca-map");
        if (mapEl) mapEl.classList.remove("selecting-location");

        // Ocultar banner
        const banner = document.getElementById("map-selection-banner");
        if (banner) {
          banner.classList.remove("active");
          setTimeout(() => {
            if (!mapSelectionMode) banner.style.display = "none";
          }, 300);
        }

        // Mostrar de nuevo los botones flotantes
        const fab = document.getElementById("btn-upload-audio");
        if (fab) fab.style.opacity = "";
        const paseoBtn = document.getElementById("btn-paseo-floating");
        if (paseoBtn) paseoBtn.style.opacity = "";

        // Restaurar panel
        if (restorePanel) {
          setPanelState(previousPanelState);
        }
      }

      function updateTempMarker(lat, lng) {
        if (tempMarker) {
          tempMarker.setLngLat([lng, lat]);
        } else {
          const el = document.createElement("div");
          el.innerHTML = `<div style="position:relative;width:24px;height:24px;box-sizing:border-box;"><div class="marker-pulse-ring" style="background:#ef4444;animation-duration:1.5s;"></div><div style="position:relative;z-index:1;width:24px;height:24px;border-radius:50%;background:#ef4444;border:2.5px solid #fff;box-shadow:0 2px 8px rgba(0,0,0,0.3);box-sizing:border-box;"></div></div>`;
          tempMarker = new maplibregl.Marker({ element: el })
            .setLngLat([lng, lat])
            .addTo(map);
        }

        if (map) {
          map.flyTo({
            center: [lng, lat],
            zoom: Math.max(map.getZoom(), 16),
            duration: 350
          });
        }
      }

      function removeTempMarker() {
        if (tempMarker) {
          tempMarker.remove();
          tempMarker = null;
        }
      }

      function openUploadModal() {
        uploadModal.classList.add("open");
        uploadModal.setAttribute("aria-hidden", "false");
        document.body.style.overflow = "hidden";
        
        // Si es parada existente, mostrar su nombre en el visor
        if (locationMode === "existing" && selectedStopId) {
          const stop = stopsData.find(s => s.id === selectedStopId);
          if (stop && pickerCoordsEl) {
            pickerCoordsEl.textContent = `📍 ${stop.name}`;
            pickerCoordsEl.className = "picker-coords has-coords";
          }
          // Bloquear color si la parada ya tiene un aporte ciudadano con color
          applyColorLockForStop(selectedStopId);
        } else {
          // Nueva parada: siempre desbloquear el selector
          setColorPickerLocked(false);
        }
      }

      function closeUploadModal(changingLocation = false) {
        isChangingLocation = changingLocation;
        uploadModal.classList.remove("open");
        uploadModal.setAttribute("aria-hidden", "true");
        document.body.style.overflow = "";
        
        if (!changingLocation) {
          setTimeout(resetUploadModal, 300);
        }
      }

      function resetUploadModal() {
        // Si se cerró para cambiar de ubicación, no reseteamos el formulario
        if (isChangingLocation) return;

        uploadForm.style.display           = "block";
        uploadProgressSection.style.display = "none";
        uploadSuccessSection.style.display  = "none";
        hideUploadError();
        uploadForm.reset();
        uploadDropzone.classList.remove("has-file");
        uploadDropzoneIcon.textContent  = "🎙️";
        uploadDropzoneLabel.textContent = "Arrastra un audio o haz clic para seleccionar";
        
        // Resetear modo
        setLocationMode("existing");
        pickerCoords = null;
        if (pickerCoordsEl) {
          pickerCoordsEl.textContent = "📍 Ninguna ubicación seleccionada";
          pickerCoordsEl.className = "picker-coords";
        }
        
        // Limpiar marcador temporal del mapa principal
        removeTempMarker();

        // Resetear origen de audio y grabadora
        setAudioSource("record");
        stopRecordingWorkflow(true);
        uploadedFile = null;
        if (uploadFileInput) uploadFileInput.value = "";
      }

      // ─── Funciones de la Grabadora de Audio ─────────────────────────────────

      function setAudioSource(source) {
        activeAudioSource = source;
        if (source === "upload") {
          tabBtnUpload?.classList.add("active");
          tabBtnUpload?.setAttribute("aria-selected", "true");
          tabBtnRecord?.classList.remove("active");
          tabBtnRecord?.setAttribute("aria-selected", "false");
          if (audioTabUpload) audioTabUpload.style.display = "block";
          if (audioTabRecord) audioTabRecord.style.display = "none";
          // Parar grabación si estaba activa
          stopRecordingWorkflow(true);
        } else {
          tabBtnRecord?.classList.add("active");
          tabBtnRecord?.setAttribute("aria-selected", "true");
          tabBtnUpload?.classList.remove("active");
          tabBtnUpload?.setAttribute("aria-selected", "false");
          if (audioTabUpload) audioTabUpload.style.display = "none";
          if (audioTabRecord) audioTabRecord.style.display = "block";
        }
      }

      function showRecorderState(state) {
        if (recStateReady)   recStateReady.style.display   = state === "ready" ? "flex" : "none";
        if (recStateActive)  recStateActive.style.display  = state === "active" ? "flex" : "none";
        if (recStatePreview) recStatePreview.style.display = state === "preview" ? "flex" : "none";
        if (recStateError)   recStateError.style.display   = state === "error" ? "flex" : "none";
      }

      async function startRecordingWorkflow() {
        audioChunks = [];
        recordedFile = null;
        recordElapsedSec = 0;
        if (recorderTimer) recorderTimer.textContent = "00:00";

        try {
          // Solicitar micrófono
          recordingStream = await navigator.mediaDevices.getUserMedia({ audio: true });
          
          // Crear MediaRecorder
          let options = {};
          if (MediaRecorder.isTypeSupported("audio/webm")) {
            options = { mimeType: "audio/webm" };
          } else if (MediaRecorder.isTypeSupported("audio/mp4")) {
            options = { mimeType: "audio/mp4" };
          } else if (MediaRecorder.isTypeSupported("audio/ogg")) {
            options = { mimeType: "audio/ogg" };
          }

          mediaRecorder = new MediaRecorder(recordingStream, options);
          
          mediaRecorder.ondataavailable = (e) => {
            if (e.data && e.data.size > 0) {
              audioChunks.push(e.data);
            }
          };

          mediaRecorder.onstop = () => {
            const mimeType = mediaRecorder.mimeType || "audio/webm";
            const blob = new Blob(audioChunks, { type: mimeType });
            
            let extension = "webm";
            if (mimeType.includes("mp4")) extension = "mp4";
            else if (mimeType.includes("ogg")) extension = "ogg";
            else if (mimeType.includes("wav")) extension = "wav";

            recordedFile = new File([blob], `grabacion_${Date.now()}.${extension}`, { type: mimeType });

            const audioURL = URL.createObjectURL(blob);
            if (previewAudio) previewAudio.src = audioURL;

            showRecorderState("preview");
            cleanupAudioContext();
          };

          mediaRecorder.start(250);

          recordStartTime = Date.now();
          recordTimerInterval = setInterval(updateRecordingTimer, 1000);

          if (visualizerCanvas) {
            initAudioVisualizer(recordingStream);
          }

          showRecorderState("active");
          if (recStateActive) recStateActive.classList.remove("paused");
          if (btnRecordPause) {
            btnRecordPause.classList.remove("active");
            btnRecordPause.innerHTML = `
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="10" y1="4" x2="10" y2="20"></line>
                <line x1="14" y1="4" x2="14" y2="20"></line>
              </svg>
            `;
          }
        } catch (err) {
          console.error("Error accessing microphone:", err);
          let msg = "No se pudo acceder al micrófono. Por favor, revisa los permisos de tu navegador.";
          if (err.name === "NotAllowedError" || err.name === "PermissionDeniedError") {
            msg = "Permiso de micrófono denegado. Actívalo en los ajustes de tu navegador para poder grabar.";
          }
          if (recErrorMsg) recErrorMsg.textContent = msg;
          showRecorderState("error");
          cleanupRecordingTracks();
        }
      }

      function togglePauseRecordingWorkflow() {
        if (!mediaRecorder || mediaRecorder.state === "inactive") return;

        if (mediaRecorder.state === "recording") {
          mediaRecorder.pause();
          if (recStateActive) recStateActive.classList.add("paused");
          if (btnRecordPause) {
            btnRecordPause.classList.add("active");
            btnRecordPause.innerHTML = `
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="5 3 19 12 5 21 5 3"></polygon>
              </svg>
            `;
          }
          if (recordTimerInterval) clearInterval(recordTimerInterval);
        } else if (mediaRecorder.state === "paused") {
          mediaRecorder.resume();
          if (recStateActive) recStateActive.classList.remove("paused");
          if (btnRecordPause) {
            btnRecordPause.classList.remove("active");
            btnRecordPause.innerHTML = `
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="10" y1="4" x2="10" y2="20"></line>
                <line x1="14" y1="4" x2="14" y2="20"></line>
              </svg>
            `;
          }
          recordStartTime = Date.now() - (recordElapsedSec * 1000);
          recordTimerInterval = setInterval(updateRecordingTimer, 1000);
        }
      }

      function stopRecordingWorkflow(discard) {
        if (recordTimerInterval) {
          clearInterval(recordTimerInterval);
          recordTimerInterval = null;
        }

        cleanupAudioContext();

        if (mediaRecorder && mediaRecorder.state !== "inactive") {
          mediaRecorder.stop();
        }

        cleanupRecordingTracks();

        if (discard) {
          audioChunks = [];
          recordedFile = null;
          if (previewAudio) previewAudio.src = "";
          showRecorderState("ready");
        }
      }

      function cleanupRecordingTracks() {
        if (recordingStream) {
          recordingStream.getTracks().forEach((track) => track.stop());
          recordingStream = null;
        }
      }

      function cleanupAudioContext() {
        if (visualizerAnimFrame) {
          cancelAnimationFrame(visualizerAnimFrame);
          visualizerAnimFrame = null;
        }
        if (audioContext) {
          if (audioContext.state !== "closed") {
            audioContext.close();
          }
          audioContext = null;
        }
        analyser = null;
      }

      function updateRecordingTimer() {
        recordElapsedSec = Math.floor((Date.now() - recordStartTime) / 1000);
        
        if (recordElapsedSec >= MAX_RECORD_TIME) {
          recordElapsedSec = MAX_RECORD_TIME;
          stopRecordingWorkflow(false);
          return;
        }

        const min = String(Math.floor(recordElapsedSec / 60)).padStart(2, "0");
        const sec = String(recordElapsedSec % 60).padStart(2, "0");
        if (recorderTimer) recorderTimer.textContent = `${min}:${sec}`;
      }

      function initAudioVisualizer(stream) {
        try {
          audioContext = new (window.AudioContext || window.webkitAudioContext)();
          const source = audioContext.createMediaStreamSource(stream);
          analyser = audioContext.createAnalyser();
          analyser.fftSize = 64;
          source.connect(analyser);

          const bufferLength = analyser.frequencyBinCount;
          const dataArray = new Uint8Array(bufferLength);

          const canvasContext = visualizerCanvas.getContext("2d");
          if (!canvasContext) return;

          const rect = visualizerCanvas.getBoundingClientRect();
          visualizerCanvas.width = rect.width;
          visualizerCanvas.height = rect.height;

          function draw() {
            if (!analyser) return;
            visualizerAnimFrame = requestAnimationFrame(draw);

            analyser.getByteFrequencyData(dataArray);

            const width = visualizerCanvas.width;
            const height = visualizerCanvas.height;

            canvasContext.fillStyle = "#fafafa";
            canvasContext.fillRect(0, 0, width, height);

            const barCount = 18;
            const barWidth = (width / barCount) - 3;
            let x = 1.5;

            for (let i = 0; i < barCount; i++) {
              const dataIdx = Math.abs(i - Math.floor(barCount / 2));
              const value = dataArray[dataIdx] || 0;
              
              const percent = value / 255;
              const barHeight = Math.max(4, percent * (height - 8));
              const y = (height - barHeight) / 2;

              canvasContext.fillStyle = "#18181b";

              canvasContext.beginPath();
              if (canvasContext.roundRect) {
                canvasContext.roundRect(x, y, barWidth, barHeight, 2);
              } else {
                canvasContext.rect(x, y, barWidth, barHeight);
              }
              canvasContext.fill();

              x += barWidth + 3;
            }
          }

          draw();
        } catch (e) {
          console.error("Error initializing visualizer:", e);
        }
      }

      // ─── Selector de color del pin ──────────────────────────────────────────

      let selectedPinColor = "#FF6A00"; // color por defecto

      function selectSwatch(color) {
        selectedPinColor = color;
        // Actualizar estado visual de los swatches
        document.querySelectorAll(".color-swatch").forEach(btn => {
          btn.classList.toggle("selected", btn.dataset.color === color);
        });
        // Actualizar el input de color personalizado
        const customInput = document.getElementById("upload-color-custom");
        if (customInput) customInput.value = color;
      }

      function setColorPickerLocked(locked) {
        document.querySelectorAll(".color-swatch").forEach(btn => {
          btn.disabled = locked;
        });
        const customInput = document.getElementById("upload-color-custom");
        if (customInput) customInput.disabled = locked;
        const lockedNote = document.getElementById("color-locked-note");
        if (lockedNote) lockedNote.classList.toggle("visible", locked);
      }

      function applyColorLockForStop(stopId) {
        const stopObj = stopsData.find(s => s.id === stopId);
        const citizenAudio = stopObj && stopObj.audios.find(a =>
          a.origin === "citizen" || a.origin === "ciudadano" || a.category === "ciudadano"
        );
        if (citizenAudio && citizenAudio.pinColor) {
          // La parada ya tiene color → forzar ese color y bloquear
          selectSwatch(citizenAudio.pinColor);
          setColorPickerLocked(true);
        } else {
          setColorPickerLocked(false);
        }
      }

      // Event listeners de swatches
      document.querySelectorAll(".color-swatch").forEach(btn => {
        btn.addEventListener("click", () => {
          if (!btn.disabled) selectSwatch(btn.dataset.color);
        });
      });

      // Input de color personalizado
      const colorCustomInput = document.getElementById("upload-color-custom");
      colorCustomInput?.addEventListener("input", (e) => {
        if (!colorCustomInput.disabled) {
          selectedPinColor = e.target.value.toUpperCase();
          // Quitar selected de todos los swatches (ninguno coincide con custom)
          document.querySelectorAll(".color-swatch").forEach(btn => btn.classList.remove("selected"));
        }
      });

      // ── Listeners de la grabadora ──

      tabBtnUpload?.addEventListener("click", () => setAudioSource("upload"));
      tabBtnRecord?.addEventListener("click", () => setAudioSource("record"));
      btnRecordStart?.addEventListener("click", startRecordingWorkflow);
      btnRecordPause?.addEventListener("click", togglePauseRecordingWorkflow);
      btnRecordStop?.addEventListener("click", () => stopRecordingWorkflow(false));
      btnRecordDiscard?.addEventListener("click", () => stopRecordingWorkflow(true));
      btnRecordRetry?.addEventListener("click", startRecordingWorkflow);

      btnUploadAudio?.addEventListener("click", enterMapSelectionMode);
      
      const btnCancelSelection = document.getElementById("btn-cancel-selection");
      btnCancelSelection?.addEventListener("click", () => exitMapSelectionMode(true));

      const btnChangeLocation = document.getElementById("btn-change-location");
      btnChangeLocation?.addEventListener("click", () => {
        closeUploadModal(true);
        setTimeout(enterMapSelectionMode, 150);
      });

      uploadModalClose?.addEventListener("click", () => closeUploadModal(false));
      uploadModal?.addEventListener("click", (e) => {
        if (e.target === uploadModal) closeUploadModal(false);
      });
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && uploadModal.classList.contains("open")) closeUploadModal(false);
      });

      // Drag-and-drop en la dropzone
      uploadDropzone?.addEventListener("dragover", (e) => {
        e.preventDefault();
        uploadDropzone.classList.add("drag-over");
      });
      uploadDropzone?.addEventListener("dragleave", () => {
        uploadDropzone.classList.remove("drag-over");
      });
      uploadDropzone?.addEventListener("drop", (e) => {
        e.preventDefault();
        uploadDropzone.classList.remove("drag-over");
        const file = e.dataTransfer?.files[0];
        if (file) {
          uploadedFile = file;
          setSelectedFile(file);
        }
      });

      uploadFileInput?.addEventListener("change", () => {
        const file = uploadFileInput.files?.[0];
        if (file) {
          uploadedFile = file;
          setSelectedFile(file);
        }
      });

      function setSelectedFile(file) {
        uploadDropzone.classList.add("has-file");
        uploadDropzoneIcon.textContent = "🎵";
        const sizeMB = (file.size / 1024 / 1024).toFixed(1);
        uploadDropzoneLabel.textContent = `${file.name} (${sizeMB} MB)`;
      }

      function showUploadError(msg) {
        uploadErrorDiv.textContent = msg;
        uploadErrorDiv.style.display = "block";
      }

      function hideUploadError() {
        uploadErrorDiv.style.display = "none";
        uploadErrorDiv.textContent = "";
      }

      function setProgress(pct, label) {
        uploadProgressBar.style.width  = `${pct}%`;
        uploadProgressLabel.textContent = label;
      }

      uploadForm?.addEventListener("submit", async (e) => {
        e.preventDefault();
        hideUploadError();

        const description = document.getElementById("upload-description")?.value?.trim();
        const author      = document.getElementById("upload-author")?.value?.trim();
        let file = null;
        if (activeAudioSource === "upload") {
          file = uploadedFile;
        } else if (activeAudioSource === "record") {
          file = recordedFile;
        }

        // Validar según el modo de ubicación
        let stopId = null;
        let stopName = "";
        let submissionCoords = null;

        if (locationMode === "existing") {
          stopId = selectedStopId;
          if (!stopId) { showUploadError("Por favor selecciona una parada en el mapa."); return; }
          const stop = stopsData.find((s) => s.id === parseInt(stopId));
          stopName = stop?.name || "";
        } else {
          // Nueva parada
          stopName = document.getElementById("upload-new-name")?.value?.trim() || "";
          if (!stopName) { showUploadError("Por favor añade un nombre para el lugar."); return; }
          if (!pickerCoords) { showUploadError("Por favor selecciona una ubicación en el mapa."); return; }
          submissionCoords = pickerCoords;
        }

        if (!description) { showUploadError("Por favor añade una descripción del sonido."); return; }
        if (!file) {
          if (activeAudioSource === "upload") {
            showUploadError("Por favor selecciona un archivo de audio.");
          } else {
            showUploadError("Por favor graba un sonido primero.");
          }
          return;
        }
        if (file.size > 100 * 1024 * 1024) { showUploadError("El archivo no puede superar los 100 MB."); return; }

        const legalCheckbox = document.getElementById("upload-legal-checkbox");
        if (legalCheckbox && !legalCheckbox.checked) {
          showUploadError("Debes aceptar los Términos de Uso y la Política de Privacidad.");
          return;
        }

        if (!uploadApiUrl) {
          showUploadError("El servicio de subida no está disponible en este momento. Escríbenos a hola@colectivoradiopatio.com.");
          return;
        }

        // Mostrar progreso
        uploadForm.style.display = "none";
        uploadProgressSection.style.display = "block";
        setProgress(10, "Preparando subida…");

        try {
          // Paso 1: Obtener URL pre-firmada de la Lambda
          const metaRes = await fetch(uploadApiUrl, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              filename:    file.name,
              mimeType:    file.type || "audio/wav",
              stopId:      stopId ? parseInt(stopId) : null,
              stopName,
              coords:      submissionCoords,  // { lat, lng } para nuevas paradas
              isNewStop:   locationMode === "new",
              description,
              author:      author || "Anónimo",
              pinColor:    selectedPinColor,
            }),
          });

          if (!metaRes.ok) {
            const errBody = await metaRes.text().catch(() => "");
            throw new Error(`Error del servidor (${metaRes.status}): ${errBody.slice(0, 200)}`);
          }

          const { uploadUrl } = await metaRes.json();
          if (!uploadUrl) throw new Error("La respuesta del servidor no incluye la URL de subida.");

          setProgress(25, "Enviando sonido…");

          // Paso 2: Subir el archivo directamente a S3 con XHR para tener progreso
          await new Promise((resolve, reject) => {
            const xhr = new XMLHttpRequest();
            xhr.open("PUT", uploadUrl);
            xhr.setRequestHeader("Content-Type", file.type || "audio/wav");

            xhr.upload.onprogress = (ev) => {
              if (ev.lengthComputable) {
                const pct = 25 + Math.round((ev.loaded / ev.total) * 70);
                setProgress(pct, `Subiendo… ${Math.round((ev.loaded / ev.total) * 100)}%`);
              }
            };

            xhr.onload = () => {
              if (xhr.status >= 200 && xhr.status < 300) {
                resolve(null);
              } else {
                reject(new Error(`Error al subir a S3 (${xhr.status})`));
              }
            };

            xhr.onerror  = () => reject(new Error("Error de red al subir el archivo."));
            xhr.ontimeout = () => reject(new Error("La subida tardó demasiado. Inténtalo de nuevo."));
            xhr.timeout = 5 * 60 * 1000; // 5 min timeout

            xhr.send(file);
          });

          setProgress(100, "¡Completado!");
          setTimeout(() => {
            uploadProgressSection.style.display = "none";
            uploadSuccessSection.style.display  = "block";
          }, 500);

        } catch (err) {
          console.error("Upload error:", err);
          uploadProgressSection.style.display = "none";
          uploadForm.style.display = "block";
          showUploadError(`Error al enviar el audio: ${err.message}`);
        }
      });

      // ─── Carga de Audios Aprobados Dinámicos ───────────────────────────────

      function addStopCardToDOM(stop) {
        const stopsList = document.getElementById("stops-list");
        if (!stopsList) return;

        // Comprobar si ya existe en el DOM
        if (document.getElementById(`stop-card-${stop.id}`)) return;

        const card = document.createElement("div");
        card.className = "stop-card citizen-stop-card";
        card.id = `stop-card-${stop.id}`;
        card.dataset.stopId = stop.id;

        card.innerHTML = `
          <div class="stop-card-header">
            <div class="stop-card-body">
              <h3>${stop.name}</h3>
              <p class="desc">${stop.description}</p>
              <span class="meta" id="meta-${stop.id}">0 audios</span>
            </div>
          </div>
          <div class="stop-player-wrapper" id="player-${stop.id}">
            <div class="stop-player-inner"></div>
          </div>
        `;

        stopsList.appendChild(card);
      }

      function addAudioToCardDOM(stopId, audio) {
        const playerInner = document.querySelector(`#player-${stopId} .stop-player-inner`);
        if (!playerInner) return;

        const item = document.createElement("div");
        item.className = "audio-item citizen-audio";
        const pinColor = audio.pinColor || "#FF6A00";

        const transcriptionHtml = audio.transcription ? `
          <div class="transcription-container" style="margin-top:6px;">
            <button
              type="button"
              class="transcription-toggle-btn"
              style="display:inline-flex;align-items:center;gap:4px;font-size:10px;font-weight:600;color:#71717a;background:none;border:none;padding:0;cursor:pointer;font-family:inherit;transition:color 0.15s;"
              onmouseenter="this.style.color='#18181b'"
              onmouseleave="if (this.nextElementSibling.classList.contains('hidden')) { this.style.color='#71717a'; } else { this.style.color='#18181b'; }"
              onclick="
                const container = this.nextElementSibling;
                const textSpan = this.querySelector('.toggle-text');
                const svg = this.querySelector('svg');
                container.classList.toggle('hidden');
                const isHidden = container.classList.contains('hidden');
                textSpan.textContent = isHidden ? 'Ver transcripción' : 'Ocultar transcripción';
                svg.style.transform = isHidden ? 'rotate(0deg)' : 'rotate(180deg)';
              "
            >
              <span class="toggle-text">Ver transcripción</span>
              <svg style="width:10px;height:10px;transition:transform 0.2s;transform-origin:center;transform:rotate(0deg);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
            </button>
            <div class="hidden transcription-text" style="margin-top:6px;padding:10px 12px;background:#fafafa;border:1px solid #e4e4e7;border-radius:10px;font-size:11px;color:#52525b;line-height:1.5;white-space:pre-line;">${audio.transcription.trim()}</div>
          </div>
        ` : "";

        item.innerHTML = `
          <p class="audio-title" style="color:${pinColor}">${audio.title}</p>
          <audio controls preload="none">
            <source src="/audio/${encodeURIComponent(audio.file)}" type="audio/wav" />
          </audio>
          ${transcriptionHtml}
        `;
        playerInner.appendChild(item);
      }

      function updateStopCardMetas() {
        stopsData.forEach(stop => {
          const card = document.getElementById(`stop-card-${stop.id}`);
          if (card) {
            const metaSpan = card.querySelector(".meta");
            if (metaSpan) {
              const citizenAudios = stop.audios.filter(a => a.origin === "citizen" || a.origin === "ciudadano" || a.category === "ciudadano");
              const generalText = `${stop.audios.length} audio${stop.audios.length !== 1 ? "s" : ""}`;
              if (citizenAudios.length > 0) {
                const pinColor = (citizenAudios[0] && citizenAudios[0].pinColor) || "#FF6A00";
                metaSpan.innerHTML = `${generalText} · <span style="color:${pinColor};font-weight:600;">aporte ciudadano</span>`;
              } else {
                metaSpan.textContent = generalText;
              }
            }
          }
        });
      }

      async function loadApprovedAudios() {
        try {
          const res = await fetch(`/audio/approved.json?t=${Date.now()}`);
          if (!res.ok) return;
          const approvedList = await res.json();
          if (!Array.isArray(approvedList)) return;

          approvedList.forEach((item, index) => {
            const tempId = 10000 + index;
            if (item.isNewStop) {
              // Nueva parada ciudadana
              let stop = stopsData.find(s => s.name === item.stopName);
              if (!stop) {
                stop = {
                  id: tempId,
                  name: item.stopName,
                  coords: [item.coords.lat, item.coords.lng],
                  description: item.description || "Nueva parada ciudadana",
                  address: item.stopName,
                  audios: []
                };
                stopsData.push(stop);
                
                // Añadir al panel lateral
                addStopCardToDOM(stop);
                
                // Si el mapa está inicializado, crear marcador
                if (map) {
                  addMarker(stop);
                }
              }
              
              const audioObj = {
                title: `${item.description} — ${item.author}`,
                file: item.audioFile,
                duration: "Voz",
                category: "ciudadano",
                origin: "citizen",
                pinColor: item.pinColor || null,
              };
              stop.audios.push(audioObj);
              addAudioToCardDOM(stop.id, audioObj);
            } else {
              // Parada existente
              const stop = stopsData.find(s => s.id === item.stopId);
              if (stop) {
                const audioObj = {
                  title: `${item.description} — ${item.author}`,
                  file: item.audioFile,
                  duration: "Voz",
                  category: "ciudadano",
                  origin: "citizen",
                  pinColor: item.pinColor || null,
                };
                stop.audios.push(audioObj);
                addAudioToCardDOM(stop.id, audioObj);
              }
            }
          });

          // Actualizar etiquetas
          updateStopCardMetas();
          
          // Re-renderizar marcadores en caso de que ya estuvieran cargados
          if (map) {
            updateMarkers(selectedStopId);
          }
        } catch (err) {
          console.warn("No se pudieron cargar los audios aprobados:", err);
        }
      }

      // ─── Init ──────────────────────────────────────────────────────────────

      document.addEventListener("DOMContentLoaded", () => {
        initMap().catch(e => console.error("Fonoteca map init error:", e));
        loadApprovedAudios();
        window.addEventListener("resize", () => { if (map) map.resize(); });

        // Pausar otros audios al reproducir uno nuevo
        document.addEventListener("play", (e) => {
          if (e.target.tagName === "AUDIO") {
            document.querySelectorAll("audio").forEach((a) => {
              if (a !== e.target && !a.paused) a.pause();
            });
          }
        }, true);

        // Listeners de ordenación
        document.querySelectorAll(".sort-toggle-btn").forEach((btn) => {
          btn.addEventListener("click", () => handleSortClick(btn));
        });

        // Toggle de atribución personalizada
        const customAttribution = document.getElementById("custom-attribution");
        const btnInfoToggle     = document.getElementById("btn-info-toggle");
        if (btnInfoToggle && customAttribution) {
          btnInfoToggle.addEventListener("click", (e) => {
            e.stopPropagation();
            customAttribution.classList.toggle("open");
          });
          // Cerrar si se pulsa fuera
          document.addEventListener("click", (e) => {
            if (!customAttribution.contains(e.target)) {
              customAttribution.classList.remove("open");
            }
          });
        }

        // Animación del botón flotante Paseo Sonoro
        const paseoBtn = document.getElementById("btn-paseo-floating");
        if (paseoBtn) {
          setTimeout(() => {
            paseoBtn.classList.add("collapsed");
          }, 2200);
        }
      });
    })();
  </script>
</DeliciasSuenaLayout>
