---
import type { Stop } from "../../data/stops"

export interface Props {
  stop: Stop
}

const { stop } = Astro.props
---

<div class="w-full border border-zinc-900 rounded-2xl p-6 bg-white space-y-4">
  <div class="flex items-center gap-3">
    <span class="inline-flex items-center justify-center w-8 h-8 rounded-full border border-zinc-900 font-sans font-semibold text-sm text-zinc-900">
      {String(stop.id).padStart(2, "0")}
    </span>
    <div class="min-w-0 flex-1">
      <h3 class="font-sans font-semibold text-lg tracking-tight text-zinc-900">{stop.name}</h3>
      <p class="font-sans text-sm text-zinc-500 leading-relaxed">{stop.description}</p>
    </div>
  </div>

  <div class="space-y-3">
    {stop.audios.map((audio) => (
      <div class="space-y-1">
        <p class="font-sans text-xs font-medium text-zinc-700 tracking-wide">{audio.title}</p>
        <audio
          controls
          preload="none"
          class="w-full h-9 rounded-lg"
          style="background: #FAFAFA;"
        >
          <source src={"/audio/" + encodeURIComponent(audio.file)} type="audio/ogg" />
        </audio>
        {audio.transcription && (
          <div class="mt-1.5">
            <button
              type="button"
              class="inline-flex items-center gap-1 text-[11px] font-sans font-semibold text-zinc-500 hover:text-zinc-900 transition-colors focus:outline-none cursor-pointer"
              onclick={`
                const container = this.nextElementSibling;
                const textSpan = this.querySelector('.toggle-text');
                const svg = this.querySelector('svg');
                container.classList.toggle('hidden');
                const isHidden = container.classList.contains('hidden');
                textSpan.textContent = isHidden ? 'Ver transcripción' : 'Ocultar transcripción';
                svg.style.transform = isHidden ? 'rotate(0deg)' : 'rotate(180deg)';
              `}
            >
              <span class="toggle-text">Ver transcripción</span>
              <svg class="w-3 h-3 transition-transform duration-200 origin-center" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" style="transform: rotate(0deg);">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
            </button>
            <div class="hidden mt-2 p-3.5 bg-zinc-50 border border-zinc-200/60 rounded-xl text-[12px] text-zinc-600 font-sans leading-relaxed whitespace-pre-line antialiased">
              {audio.transcription}
            </div>
          </div>
        )}
      </div>
    ))}
  </div>
</div>
