# Variables de entorno necesarias para Delicias Suena

# URL de la AWS Lambda que gestiona la fonoteca (subida de grabaciones y administración)
# Despliega tu propia función Lambda o usa cualquier backend compatible.
PUBLIC_UPLOAD_API_URL=https://tu-lambda-function-url.amazonaws.com

# Contraseña del panel de administración de la fonoteca (/proyectos/deliciassuena/admin)
ADMIN_PASSWORD=tu-contraseña-secreta

# Email desde el que se envían las notificaciones de nuevas grabaciones (requiere SES u otro proveedor SMTP)
FROM_EMAIL=tu-email@ejemplo.com

# Email donde recibirás las notificaciones de nuevas grabaciones pendientes de revisión
NOTIFY_EMAIL=notificaciones@ejemplo.com
